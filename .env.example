# Shia Hadith Fullstack Platform - Deployment Environment Variables Template

# 1. PostgreSQL Vector Database (Read-only User for security)
POSTGRES_URL=postgresql://username:password@host:port/database

# 2. Google Gemini API Configuration (Model: gemini-3.5-flash / gemini-embedding-2)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_GENERATIVE_API_KEY=your_gemini_api_key_here
